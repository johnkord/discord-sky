{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Transcript": {
    "Enabled": true,
    "BaseDirectory": "data/transcripts",
    "RetentionDays": 14
  },
  "Reactions": {
    "Enabled": true,
    "BaseDirectory": "data/reactions",
    "RetentionDays": 30
  },
  "Image": {
    "Enabled": false,
    "ProviderName": "OpenAI",
    "Model": "gpt-image-1-mini",
    "Size": "1024x1024",
    "Quality": "low",
    "OutputFormat": "jpeg",
    "Moderation": "auto",
    "PerUserPerHour": 2,
    "GlobalPerDay": 25,
    "MaxConcurrent": 2,
    "MonthlyUsdGuard": 20.0,
    "AllowHighQuality": false,
    "BaseDirectory": "data/images",
    "RetentionDays": 60
  },
  "Bot": {
    "Token": "",
    "Status": "SnooPING AS usual",
    "AllowedChannelNames": [],
    "CommandPrefix": "!sky",
    "HistoryMessageLimit": 20,
    "DefaultPersona": "Robotnik from AOSTH",
    "ReplyChainDepth": 40,
    "IncludeOwnMessagesInHistory": true,
    "EnableUserMemory": true,
    "MaxMemoriesPerUser": 20,
    "MemoryExtractionModel": "gpt-5.5",
    "MemoryExtractionRate": 1.0,
    "MemoryDataPath": "data/user_memories",
    "ConversationWindowTimeout": "00:03:00",
    "MaxWindowMessages": 30,
    "MaxWindowDuration": "00:30:00",
    "MaxMemoriesPerExtraction": 15
  },
  "Chaos": {
    "MaxPromptsPerHour": 20,
    "BanWords": [],
    "AmbientReplyChance": 0.25
  },
  "MemoryRelevance": {
    "Mode": "ShadowOnly",
    "HardFloor": 0.15,
    "AdmissionThreshold": 0.35,
    "ConfidenceGap": 2.0,
    "MaxInjectedMemories": 2,
    "LateralInhibition": 0.5,
    "RecentMessageWindow": 3,
    "SuppressionOverlapThreshold": 0.3,
    "KindAmbientThreshold": {
      "Factual": 0.35,
      "Experiential": 0.85,
      "Running": 999999.0,
      "Meta": 999999.0
    }
  },
  "LLM": {
    "ActiveProvider": "OpenAI",
    "Providers": {
      "OpenAI": {
        "ApiKey": "",
        "ChatModel": "gpt-5.5",
        "MaxTokens": 1200,
        "IntentModelOverrides": {},
        "ReasoningEffort": "medium",
        "UseResponsesApi": true
      },
      "xAI": {
        "ApiKey": "",
        "Endpoint": "https://api.x.ai/v1",
        "ChatModel": "grok-4.20-0309-reasoning",
        "MemoryExtractionModel": "grok-4.20-0309-non-reasoning",
        "MaxTokens": 1200,
        "IntentModelOverrides": {},
        "UseResponsesApi": false
      }
    }
  }
}
